# Google AI (Gemini) - Requerido para /live
GOOGLE_GENERATIVE_AI_API_KEY=

# Webhook legacy (se mantiene para /legacy)
WEBHOOK_URL=

# Webhook de n8n para envío de diagnóstico por email
N8N_INFORME_WEBHOOK_URL=

# URL pública de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secreto compartido con n8n. Se envía como Authorization: Bearer <secret>.
N8N_WEBHOOK_SECRET=

# Tamaño máximo permitido para uploads de audio (bytes). Default: 10 MB.
MAX_AUDIO_BYTES=10485760

# Timeout (ms) para llamadas a Gemini. Default: 25000.
GEMINI_TIMEOUT_MS=25000
